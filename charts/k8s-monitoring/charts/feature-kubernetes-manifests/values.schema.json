{
    "$schema": "http://json-schema.org/schema#",
    "type": "object",
    "properties": {
        "deployAsConfigMap": {
            "type": "boolean"
        },
        "image": {
            "type": "object",
            "properties": {
                "digest": {
                    "type": "string"
                },
                "pullPolicy": {
                    "type": "string"
                },
                "pullSecrets": {
                    "type": "array"
                },
                "registry": {
                    "type": "string"
                },
                "repository": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                }
            }
        },
        "namespaces": {
            "type": "array"
        },
        "pods": {
            "type": "object",
            "properties": {
                "gather": {
                    "type": "boolean"
                }
            }
        }
    }
}
