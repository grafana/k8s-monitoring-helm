            // drop certain log levels
            stage.drop {
              source = "level"
              expression = "(?i)(debug)"
              drop_counter_reason = "mimir-drop-log-level"
            }

          }

          forward_to = argument.logs_destinations.value
        } // loki.secretfilter "pod_logs"
      } // declare "pod_logs_via_loki"
